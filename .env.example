# =============================================================
# BPR Perdana E-Form Backend — Environment Configuration
# =============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in all values marked with <REPLACE_THIS>
#   3. NEVER commit the real .env file to Git
#   4. In production (Linux cloud), set these as real OS environment
#      variables instead of using a .env file
# =============================================================


# -------------------------------------------------------------
# APPLICATION
# -------------------------------------------------------------
APP_NAME=bpr-perdana-eform
APP_ENV=development          # development | staging | production
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# Allowed frontend origins for CORS
# Separate multiple with comma: https://eform.bprperdana.co.id,https://admin.bprperdana.co.id
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001


# -------------------------------------------------------------
# DATABASE (MySQL)
# -------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bpr_perdana_eform
DB_USER=<REPLACE_THIS>
DB_PASSWORD=<REPLACE_THIS>
DB_MAX_OPEN_CONNS=25         # Maximum number of open connections to the DB
DB_MAX_IDLE_CONNS=10         # Maximum number of idle connections in the pool
DB_CONN_MAX_LIFETIME=5m      # How long a connection can be reused before closing


# -------------------------------------------------------------
# REDIS (Session & Rate Limiting)
# -------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=              # Leave empty if no auth required (dev only)
REDIS_DB=0
REDIS_POOL_SIZE=10


# -------------------------------------------------------------
# JWT — Internal Staff Authentication
# We use RS256 (asymmetric): private key signs, public key verifies.
# This means even if someone gets the public key, they can't forge tokens.
# Generate keys with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the contents below (replace newlines with \n)
# -------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TOKEN_TTL=15m     # Short-lived access token
JWT_REFRESH_TOKEN_TTL=24h    # Refresh token lives longer


# -------------------------------------------------------------
# CUSTOMER SESSION
# Customer sessions use HMAC-signed tokens (simpler than RS256
# since customers don't need multi-service auth)
# -------------------------------------------------------------
SESSION_SECRET_KEY=<REPLACE_THIS_WITH_32_CHAR_RANDOM_STRING>
SESSION_TTL_MINUTES=120      # Overridden by system_config if set


# -------------------------------------------------------------
# FILE STORAGE (Local)
# -------------------------------------------------------------
STORAGE_BASE_PATH=/var/app/storage
# Sub-paths are managed automatically by the app:
#   {STORAGE_BASE_PATH}/ktp/{year}/{month}/
#   {STORAGE_BASE_PATH}/selfie/{year}/{month}/
#   {STORAGE_BASE_PATH}/collateral/{year}/{month}/
#   {STORAGE_BASE_PATH}/contracts/{year}/{month}/
STORAGE_MAX_KTP_SIZE_MB=5
STORAGE_MAX_COLLATERAL_SIZE_MB=10
STORAGE_MAX_CONTRACT_SIZE_MB=20


